void main() {
	uint i = gl_GlobalInvocationID.x;
	if (i >= uint(params.grid_dims.w)) {
		return;
	}
	vec4 pred = predicted_src.data[i];
	uint c = cell_index(cell_of(pred.xyz));
	uint slot = cell_start.data[c] + atomicAdd(cell_count.data[c], 1u);
	predicted.data[slot] = pred;
	positions.data[slot] = positions_src.data[i];
	velocities.data[slot] = velocities_src.data[i];
}
