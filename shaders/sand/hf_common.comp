layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, r32f) uniform restrict image2D height_src;
layout(set = 0, binding = 1, r32f) uniform restrict image2D height_dst;

layout(push_constant) uniform Params {
	vec4 tool; // world x, world z, brush radius, brush strength
	vec4 flow; // slope threshold per cell, transfer rate, cell size, dt
	ivec4 misc; // grid n, tool mode
} params;
