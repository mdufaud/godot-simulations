void main() {
	uint i = gl_GlobalInvocationID.x;
	if (i >= uint(params.grid_dims.w)) {
		return;
	}
	vec3 v = velocities.data[i].xyz + params.gravity.xyz * params.solver.x;
	vec3 p = positions.data[i].xyz + v * params.solver.x;
	velocities.data[i] = vec4(v, 0.0);
	predicted.data[i] = vec4(clamp_domain(p), 0.0);
}
